{
  "info": {
    "name": "Zillow API - Complete Collection",
    "description": "Complete Zillow Real Estate API collection via RapidAPI. Covers property search, property details, Zestimates, market data, agent/broker info, mortgage rates, and more.\n\n## Setup\n1. Sign up at https://rapidapi.com\n2. Subscribe to the Zillow API (zillow-com1)\n3. Copy your RapidAPI key and set it in the `rapidapi_key` collection variable\n\n## Authentication\nAll requests use `X-RapidAPI-Key` header authentication via the `{{rapidapi_key}}` variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "zillow-api-complete-2026"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://zillow-com1.p.rapidapi.com",
      "type": "string"
    },
    {
      "key": "rapidapi_key",
      "value": "YOUR_RAPIDAPI_KEY_HERE",
      "type": "string"
    },
    {
      "key": "rapidapi_host",
      "value": "zillow-com1.p.rapidapi.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏠 Property Search",
      "description": "Search for properties using various criteria including location, filters, coordinates, and Zillow URLs.",
      "item": [
        {
          "name": "Search Properties by Location",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidapi_key}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidapi_host}}" }
            ],
            "url": {
              "raw": "{{base_url}}/propertyExtendedSearch?location=houston, tx&status_type=ForSale&home_type=Houses&sort=Newest&page=1",
              "host": ["{{base_url}}"],
              "path": ["propertyExtendedSearch"],
              "query": [
                { "key": "location", "value": "houston, tx", "description": "City, state or ZIP code" },
                { "key": "status_type", "value": "ForSale", "description": "ForSale, ForRent, RecentlySold" },
                { "key": "home_type", "value": "Houses", "description": "Houses, Apartments, Condos, Townhomes, Multi-family, Manufactured, LotsLand" },
                { "key": "sort", "value": "Newest", "description": "Newest, Price_High_Low, Price_Low_High, Beds, Baths, Square_Feet" },
                { "key": "page", "value": "1", "description": "Page number for pagination" }
              ]
            },
            "description": "Search properties by city/state or ZIP code with various filters including status, home type, and sorting."
          }
        },
        {
          "name": "Search Properties with Price Filter",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-RapidAPI-Key", "value": "{{rapidapi_key}}" },
              { "key": "X-RapidAPI-Host", "value": "{{rapidapi_host}}" }
            ],
            "url": {
              "raw": "{{base_url}}/propertyExtendedSearch?location=san francisco, ca&status_type=ForSale&home_type=Houses&minPrice=500000&maxPrice=1500000&bedsMin=3&bathsMin=2&sqftMin=1500&page=1",
              "host": ["{{base_url}}"],
              "path": ["propertyExtendedSearch"],
              "query": [
                { "key": "location", "value": "san francisco, ca" },
                { "key": "status_type", "value": "ForSale" },
                { "key": "home_type", "value": "Houses" },
                { "key": "minPrice", "value": "500000", "description": "Minimum price filter" },
                { "key": "maxPrice", "value": "1500000", "description": "Maximum price filter" },
                { "key": "bedsMin", "value": "3", "description": "Minimum bedrooms" },
                { "key": "bathsMin", "value": "2", "description": "Minimum bathrooms" },
                { "key": "sqftMin", "value": "1500", "description": "Minimum square footage" },
                { "key": "page", "value": "1" }
